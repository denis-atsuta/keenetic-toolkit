{
  "name": "keenetic-toolkit",
  "description": "Chrome extension to manage Keenetic router connection policies and static routes without opening the web UI",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run compile && npm run lint && npm run format:check",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tldts-experimental": "^7.4.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "shell-quote": "^1.10.0",
    "uuid": "^11.1.1"
  }
}
